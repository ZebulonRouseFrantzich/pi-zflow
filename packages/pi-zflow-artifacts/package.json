{
  "name": "pi-zflow-artifacts",
  "version": "0.1.0",
  "private": true,
  "description": "pi-zflow runtime state path resolution, plan/run/review artifact helpers, planner artifact write tool",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./artifact-paths": "./src/artifact-paths.ts",
    "./state-index": "./src/state-index.ts",
    "./plan-state": "./src/plan-state.ts",
    "./run-state": "./src/run-state.ts",
    "./cleanup-metadata": "./src/cleanup-metadata.ts",
    "./write-plan-artifact": "./src/write-plan-artifact.ts",
    "./package.json": "./package.json"
  },
  "keywords": [
    "pi-package",
    "pi-zflow"
  ],
  "license": "MIT",
  "dependencies": {
    "pi-zflow-core": "0.1.0"
  },
  "peerDependencies": {
    "@earendil-works/pi-coding-agent": "*",
    "@earendil-works/pi-ai": "*",
    "@earendil-works/pi-agent-core": "*",
    "typebox": "*"
  },
  "pi": {
    "extensions": [
      "./extensions"
    ]
  }
}
