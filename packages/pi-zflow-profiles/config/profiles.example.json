{
  "default": {
    "description": "Default profile — general-purpose planning, implementation, and review with the full lane set.",

    "lanes": {
      "scout-cheap": {
        "required": true,
        "thinking": "low",
        "preferredModels": [
          "opencode-go/deepseek-v4-flash",
          "opencode-go/qwen3.6-plus"
        ]
      },
      "planning-frontier": {
        "required": true,
        "thinking": "high",
        "preferredModels": ["openai-codex/gpt-5.4", "opencode-go/mimo-v2.5-pro"]
      },
      "worker-cheap": {
        "required": true,
        "thinking": "medium",
        "preferredModels": [
          "openai-codex/gpt-5.4-mini",
          "opencode-go/deepseek-v4-flash"
        ]
      },
      "worker-strong": {
        "required": true,
        "thinking": "high",
        "preferredModels": ["openai-codex/gpt-5.4", "opencode-go/mimo-v2.5-pro"]
      },
      "review-correctness": {
        "required": true,
        "thinking": "medium",
        "preferredModels": [
          "openai-codex/gpt-5.3-codex",
          "opencode-go/qwen3.6-plus"
        ]
      },
      "review-integration": {
        "required": true,
        "thinking": "medium",
        "preferredModels": [
          "openai-codex/gpt-5.3-codex",
          "opencode-go/qwen3.6-plus"
        ]
      },
      "review-security": {
        "required": true,
        "thinking": "high",
        "preferredModels": [
          "openai-codex/gpt-5.3-codex",
          "opencode-go/qwen3.6-plus"
        ]
      },
      "review-logic": {
        "optional": true,
        "thinking": "medium",
        "preferredModels": [
          "openai-codex/gpt-5.3-codex",
          "opencode-go/qwen3.6-plus"
        ]
      },
      "review-system": {
        "optional": true,
        "thinking": "high",
        "preferredModels": [
          "openai-codex/gpt-5.3-codex",
          "opencode-go/qwen3.6-plus"
        ]
      },
      "synthesis-frontier": {
        "required": true,
        "thinking": "high",
        "preferredModels": ["openai-codex/gpt-5.4", "opencode-go/mimo-v2.5-pro"]
      }
    },

    "agentBindings": {
      "scout": {
        "lane": "scout-cheap",
        "tools": "read, grep, find, ls, bash",
        "maxOutput": 6000,
        "maxSubagentDepth": 0
      },
      "zflow.planner-frontier": {
        "lane": "planning-frontier",
        "tools": "read, grep, find, ls, bash, zflow_write_plan_artifact",
        "maxOutput": 12000,
        "maxSubagentDepth": 1
      },
      "zflow.plan-validator": {
        "lane": "worker-cheap",
        "tools": "read, grep, find, ls",
        "maxOutput": 6000,
        "maxSubagentDepth": 0
      },
      "context-builder": {
        "lane": "scout-cheap",
        "tools": "read, grep, find, ls",
        "maxOutput": 6000,
        "maxSubagentDepth": 0
      },
      "zflow.implement-routine": {
        "lane": "worker-cheap",
        "tools": "read, grep, find, ls, bash, edit, write",
        "maxOutput": 8000,
        "maxSubagentDepth": 0
      },
      "zflow.implement-hard": {
        "lane": "worker-strong",
        "tools": "read, grep, find, ls, bash, edit, write",
        "maxOutput": 10000,
        "maxSubagentDepth": 0
      },
      "zflow.verifier": {
        "lane": "worker-cheap",
        "tools": "read, grep, find, ls, bash",
        "maxOutput": 6000,
        "maxSubagentDepth": 0
      },
      "zflow.review-correctness": {
        "lane": "review-correctness",
        "tools": "read, grep, find, ls, code_search, fetch_content",
        "maxOutput": 10000,
        "maxSubagentDepth": 0
      },
      "zflow.review-integration": {
        "lane": "review-integration",
        "tools": "read, grep, find, ls, intercom",
        "maxOutput": 8000,
        "maxSubagentDepth": 0
      },
      "zflow.review-security": {
        "lane": "review-security",
        "tools": "read, grep, find, ls, bash, code_search",
        "maxOutput": 8000,
        "maxSubagentDepth": 0
      },
      "zflow.review-logic": {
        "lane": "review-logic",
        "optional": true,
        "tools": "read, grep, find, ls, code_search",
        "maxOutput": 10000,
        "maxSubagentDepth": 0
      },
      "zflow.review-system": {
        "lane": "review-system",
        "optional": true,
        "tools": "read, grep, find, ls, bash, code_search",
        "maxOutput": 12000,
        "maxSubagentDepth": 0
      },
      "zflow.synthesizer": {
        "lane": "synthesis-frontier",
        "tools": "read",
        "maxOutput": 12000,
        "maxSubagentDepth": 0
      },
      "zflow.repo-mapper": {
        "lane": "scout-cheap",
        "tools": "read, bash, grep, find, ls",
        "maxOutput": 6000,
        "maxSubagentDepth": 0
      },
      "zflow.plan-review-correctness": {
        "lane": "review-correctness",
        "tools": "read, grep, find, ls",
        "maxOutput": 10000,
        "maxSubagentDepth": 0
      },
      "zflow.plan-review-integration": {
        "lane": "review-integration",
        "tools": "read, grep, find, ls",
        "maxOutput": 8000,
        "maxSubagentDepth": 0
      },
      "zflow.plan-review-feasibility": {
        "lane": "review-correctness",
        "optional": true,
        "tools": "read, grep, find, ls, bash",
        "maxOutput": 10000,
        "maxSubagentDepth": 0
      }
    },

    "verificationCommand": "npm test"
  }
}
